# ===========================================
# Environment Variables for SaaS Forecasting App
# ===========================================
# Copy this file to .env.local and fill in your values

# Supabase Configuration
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only service role key (required for account deletion).
# NEVER expose this to the browser or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: comma-separated emails with permanent free access (owner/test accounts).
# Example: FREE_ACCESS_EMAILS=you@example.com,teammate@example.com
FREE_ACCESS_EMAILS=

# Billing gate: set to true in config/plans.ts (BILLING_GATE_ENABLED) to enforce
# trial + subscription lockout. When false, all authenticated users have full access.

# Database Connection (Supabase PostgreSQL)
# Get this from Supabase: Settings > Database > Connection string > URI
# Use the "Transaction pooler" connection string (port 6543)
# IMPORTANT: URL-encode special characters in password:
#   $ -> %24
#   ! -> %21
#   @ -> %40
#   # -> %23
POSTGRES_PRISMA_URL=postgres://postgres.your-project-id:your-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Optional: Direct connection for migrations (port 5432)
# DATABASE_URL=postgres://postgres.your-project-id:your-password@aws-0-region.pooler.supabase.com:5432/postgres

# Stripe (sandbox keys from Dashboard → Developers → API keys)
# Never commit real keys. Use .env.local locally and your host's secret store in production.
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Burnlytics subscription price IDs — run `npm run setup:stripe` to create in sandbox
STRIPE_GROWTH_MONTHLY_EUR_PRICE_ID=price_your-monthly-eur-id
STRIPE_GROWTH_ANNUAL_EUR_PRICE_ID=price_your-annual-eur-id
STRIPE_GROWTH_MONTHLY_USD_PRICE_ID=price_your-monthly-usd-id
STRIPE_GROWTH_ANNUAL_USD_PRICE_ID=price_your-annual-usd-id
NEXT_PUBLIC_STRIPE_GROWTH_MONTHLY_EUR_PRICE_ID=price_your-monthly-eur-id
NEXT_PUBLIC_STRIPE_GROWTH_ANNUAL_EUR_PRICE_ID=price_your-annual-eur-id
NEXT_PUBLIC_STRIPE_GROWTH_MONTHLY_USD_PRICE_ID=price_your-monthly-usd-id
NEXT_PUBLIC_STRIPE_GROWTH_ANNUAL_USD_PRICE_ID=price_your-annual-usd-id
